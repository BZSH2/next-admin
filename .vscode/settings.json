{
  "git.ignoreLimitWarning": true,
  "files.exclude": {
    "**/.pnpm-store": true
  },
  "cSpell.ignoreWords": [
    "pnpm",
    "Caddyfile",
    "deploy",
    "nextadmin",
    "aliyun",
    "dockercompose",
    "unocss",
    "tsconfig",
    "eslint",
    "stylelint",
    "husky",
    "commitlint",
    "prettier",
    "czg",
    "czgit",
    "commitizen",
    "lintstaged",
    "buildx",
    "ssh"
  ],
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "pnpm-lock.yaml, tsconfig.tsbuildinfo, .pnpm-store",
    "next.config.ts": "src/types/next-env.d.ts, tsconfig.json, postcss.config.mjs, uno.config.ts",
    "tsconfig.json": "tsconfig.*.json",
    ".gitignore": ".gitattributes",
    ".env": ".env.*",
    "eslint.config.ts": ".eslintignore.json, .lintstagedrc.mjs, stylelint.config.mjs, commitlint.config.cjs, .commitlintrc.json, cz.config.cjs, .czrc, .prettierrc.json, .prettierignore",
    "Dockerfile": "docker-compose.prod.yml, .dockerignore",
    ".github/deploy/deploy.sh": ".github/deploy/Caddyfile.next.admin.example",
    "README.md": "AGENTS.md, CLAUDE.md"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "prettier.requireConfig": true,
  "eslint.useFlatConfig": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "stylelint.validate": ["css", "scss"],
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "cSpell.words": [
    "addgroup",
    "adduser",
    "bzsh",
    "commitlintrc",
    "HEALTHCHECK",
    "lintable",
    "necolas",
    "nextjs",
    "nosniff",
    "preflights",
    "SAMEORIGIN",
    "vercel",
    "webp",
    "zstd"
  ]
}
