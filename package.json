{
  "name": "next-admin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "commit": "git-cz",
    "cz": "git add . && git-cz",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze:uncss": "node scripts/run-uncss.cjs",
    "check": "pnpm check:lint && pnpm check:format",
    "check:eslint": "pnpm lint:eslint",
    "check:format": "pnpm format:check",
    "check:lint": "pnpm check:eslint && pnpm check:stylelint",
    "check:stylelint": "pnpm lint:style",
    "lint": "pnpm check:lint",
    "lint:fix": "pnpm lint:eslint:fix && pnpm lint:style:fix && pnpm format",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:eslint:fix": "eslint . --fix",
    "lint:commit": "commitlint --last --verbose",
    "lint:style": "stylelint \"**/*.{css,scss}\" --allow-empty-input",
    "lint:style:fix": "stylelint \"**/*.{css,scss}\" --fix --allow-empty-input",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint:staged": "lint-staged",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "uncss": "^0.17.3"
  }
}
